{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hiveping.dev/schema/get-hiveping-config.error.schema.json",
  "title": "GetHivePingConfigErrorResponse",
  "type": "object",
  "additionalProperties": false,
  "required": ["ok", "error"],
  "properties": {
    "ok": {
      "type": "boolean",
      "const": false
    },
    "requestId": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128
    },
    "error": {
      "type": "object",
      "additionalProperties": false,
      "required": ["code", "message"],
      "properties": {
        "code": {
          "type": "string",
          "enum": [
            "BAD_REQUEST",
            "ORG_NOT_FOUND",
            "USER_NOT_AUTHORIZED",
            "CONFIG_NOT_AVAILABLE",
            "INTERNAL_ERROR"
          ]
        },
        "message": {
          "type": "string",
          "minLength": 1,
          "maxLength": 512
        },
        "details": {
          "type": "object",
          "additionalProperties": true
        }
      }
    }
  }
}
