{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hiveping.dev/schema/get-hiveping-config.request.schema.json",
  "title": "GetHivePingConfigRequest",
  "type": "object",
  "additionalProperties": false,
  "required": ["organizationName"],
  "properties": {
    "organizationName": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9_-]{1,119}$",
      "description": "Stable organization slug"
    },
    "provider": {
      "type": "string",
      "enum": ["discord", "slack", "msteams", "unknown"]
    },
    "conversationKey": {
      "type": "string",
      "minLength": 1,
      "maxLength": 512
    },
    "action": {
      "type": "string",
      "enum": ["bind", "ask", "status", "unbind"]
    },
    "user": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1,
          "maxLength": 256
        },
        "displayName": {
          "type": "string",
          "minLength": 1,
          "maxLength": 256
        },
        "email": {
          "type": "string",
          "format": "email"
        }
      }
    },
    "requested": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "projectId": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128
        },
        "repoPath": {
          "type": "string",
          "minLength": 1,
          "maxLength": 2048
        }
      }
    },
    "context": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "accountId": {
          "type": "string",
          "minLength": 1,
          "maxLength": 256
        },
        "channelId": {
          "type": "string",
          "minLength": 1,
          "maxLength": 256
        },
        "threadId": {
          "type": "string",
          "minLength": 1,
          "maxLength": 256
        }
      }
    },
    "client": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "pluginId": {
          "type": "string",
          "const": "hiveping"
        },
        "pluginVersion": {
          "type": "string",
          "minLength": 1,
          "maxLength": 64
        }
      }
    }
  }
}
