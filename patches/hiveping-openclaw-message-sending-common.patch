+import { getGlobalHookRunner } from "../plugins/hook-runner-global.js";
+
+type MessageSendingMetadata = Record<string, unknown>;
+
+export async function applyOutboundMessageSendingHook(params: {
+  channelId: string;
+  to: string;
+  content: string;
+  accountId?: string;
+  conversationId?: string;
+  metadata?: MessageSendingMetadata;
+}): Promise<{ cancelled: boolean; content: string }> {
+  const hookRunner = getGlobalHookRunner();
+  if (!hookRunner?.hasHooks("message_sending")) {
+    return { cancelled: false, content: params.content };
+  }
+
+  const hookResult = await hookRunner.runMessageSending(
+    {
+      to: params.to,
+      content: params.content,
+      metadata: {
+        channelId: params.channelId,
+        ...(params.metadata || {}),
+      },
+    },
+    {
+      channelId: params.channelId,
+      accountId: params.accountId ?? undefined,
+      conversationId: params.conversationId ?? params.to,
+    },
+  );
+
+  if (hookResult?.cancel) {
+    return {
+      cancelled: true,
+      content: params.content,
+    };
+  }
+
+  return {
+    cancelled: false,
+    content: hookResult?.content ?? params.content,
+  };
+}
